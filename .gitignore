# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
deploy_key
deploy_key.pub

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
dev.err

# env files (can opt-in for committing if needed)
.env*
.env
.env.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Mylio and Unistore files
.Mylio_Catalog/
**/Unistore/
**/Mylio/
*.dat
*.uca
AggregateCache.uca

# Uploaded files
/public/uploads/resumes/*
!/public/uploads/resumes/.gitkeep

# Temporary / generated artifacts
/tmp/
tmp/
temp_*
build_output.txt
build-latest.txt
build_output_latest.txt